
# The connection string for your Neon database
# Get this from the Neon Console (Settings -> Connection String)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Firebase Admin SDK Configuration
# Option 1: Provide the path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option 2: Individual variables (if using individual credentials in code)
# FIREBASE_PROJECT_ID=classcheck-69e1d
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@classcheck-69e1d.iam.gserviceaccount.com
